{
  "permissions": {
    "deny": [
      "Edit(reference/**)",
      "Write(reference/**)",
      "NotebookEdit(reference/**)"
    ],
    "ask": [
      "Edit(docs/scriptorium/**)",
      "Write(docs/scriptorium/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-edit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit.sh"
          }
        ]
      }
    ]
  }
}
